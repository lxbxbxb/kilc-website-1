---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromUrl } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  lastUpdated?: string;
}

const locale = getLocaleFromUrl(Astro.url);
const { title, description, lastUpdated } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header locale={locale} />
  <main class="max-w-4xl mx-auto px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-serif font-bold text-brand-dark mb-4">{title}</h1>
    {lastUpdated && (
      <p class="text-sm text-gray-500 mb-8">
        {locale === 'zh' ? '最后更新：' : 'Last updated: '}{lastUpdated}
      </p>
    )}
    <article class="prose prose-lg max-w-none prose-headings:font-sans prose-headings:text-brand-dark prose-a:text-brand-accent">
      <slot />
    </article>
  </main>
  <Footer locale={locale} />
</BaseLayout>
