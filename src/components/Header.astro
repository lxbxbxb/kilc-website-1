---
import LanguageToggle from './LanguageToggle.astro';
import ThemeToggle from './ThemeToggle.astro';
import { t, getAlternateUrl } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { label: t(locale, 'nav.home'), href: locale === 'zh' ? '/zh' : '/' },
  { label: t(locale, 'nav.about'), href: locale === 'zh' ? '/zh/about' : '/about' },
  { label: t(locale, 'nav.people'), href: locale === 'zh' ? '/zh/people' : '/people' },
  {
    label: t(locale, 'nav.services'),
    href: locale === 'zh' ? '/zh/services' : '/services',
    children: [
      { label: t(locale, 'nav.globalMarket'), href: locale === 'zh' ? '/zh/global-market-strategy' : '/global-market-navigation' },
      { label: t(locale, 'nav.immigration'), href: locale === 'zh' ? '/zh/immigration-advisory' : '/immigration' },
      { label: t(locale, 'nav.criminal'), href: locale === 'zh' ? '/zh/criminal-defence' : '/criminal' },
      { label: t(locale, 'nav.studentServices'), href: locale === 'zh' ? '/zh/student-services' : '/student-services' },
      { label: t(locale, 'nav.estateInvestment'), href: locale === 'zh' ? '/zh/real-estate-investment-protection' : '/estate-investment' },
      { label: t(locale, 'nav.companyFormation'), href: locale === 'zh' ? '/zh/company-formation' : '/company-formation' },
    ],
  },
  { label: t(locale, 'nav.xos'), href: 'https://xos.kilc.co.uk' },
  { label: t(locale, 'nav.programme'), href: locale === 'zh' ? '/zh/programme' : '/programme' },
  { label: t(locale, 'nav.careers'), href: locale === 'zh' ? '/zh/careers' : '/careers' },
  { label: t(locale, 'nav.blog'), href: locale === 'zh' ? '/zh/blogs' : '/blogs' },
  { label: t(locale, 'nav.contact'), href: locale === 'zh' ? '/zh/contact-us' : '/contact' },
];

const alternatePath = getAlternateUrl(currentPath, locale);
const subtitle = locale === 'zh' ? '国际法律咨询' : 'International Legal Consultancy';
---

<!-- Top ticker — XOS-style, slim live strip -->
<div class="xos-ticker">
  <div class="xos-ticker-inner">
    <span class="xos-ticker-dot"></span>
    <span>{locale === 'zh' ? 'XOS 已上线' : 'XOS NOW LIVE'}</span>
    <span class="xos-ticker-sep">·</span>
    <span>{locale === 'zh' ? '跨境合规操作系统' : 'CROSS-BORDER COMPLIANCE OPERATING SYSTEM'}</span>
    <span class="xos-ticker-sep">·</span>
    <span>{locale === 'zh' ? '客安出品' : 'BY KILC'}</span>
  </div>
</div>

<header class="xos-nav">
  <div class="xos-nav-inner">
    <!-- Brand mark — text-based, XOS style -->
    <a href={locale === 'zh' ? '/zh' : '/'} class="xos-brand">
      <span class="xos-brand-mark">KILC</span>
      <span class="xos-brand-div"></span>
      <span class="xos-brand-sub">{subtitle}</span>
    </a>

    <!-- Desktop nav -->
    <nav class="xos-nav-links hidden lg:flex">
      {navItems.map((item) => (
        item.children ? (
          <div class="xos-nav-group">
            <a
              href={item.href}
              class:list={[
                'xos-nav-link',
                currentPath === item.href && 'is-active',
              ]}
            >
              {item.label}
              <svg class="w-2.5 h-2.5 ml-1 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
            <div class="xos-dropdown">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class:list={[
                    'xos-dropdown-item',
                    currentPath === child.href && 'is-active',
                  ]}
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            target={item.href.startsWith('http') ? '_blank' : undefined}
            rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class:list={[
              'xos-nav-link',
              currentPath === item.href || (item.href !== '/' && item.href !== '/zh' && !item.href.startsWith('http') && currentPath.startsWith(item.href)) ? 'is-active' : '',
            ]}
          >
            {item.label}
          </a>
        )
      ))}
    </nav>

    <!-- Right cluster — toggles + Open XOS -->
    <div class="xos-nav-right hidden lg:flex">
      <ThemeToggle />
      <LanguageToggle locale={locale} alternatePath={alternatePath} />
      <a href="https://xos.kilc.co.uk" target="_blank" rel="noopener noreferrer" class="btn-xos">
        {locale === 'zh' ? '打开 XOS' : 'Open XOS'}
      </a>
    </div>

    <!-- Mobile cluster -->
    <div class="flex items-center gap-2 lg:hidden">
      <ThemeToggle />
      <LanguageToggle locale={locale} alternatePath={alternatePath} />
      <button
        id="mobile-menu-btn"
        type="button"
        class="xos-icon-btn"
        aria-label="Open menu"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="xos-mobile-nav hidden lg:hidden">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
      {navItems.map((item) => (
        <>
          <a
            href={item.href}
            target={item.href.startsWith('http') ? '_blank' : undefined}
            rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class:list={[
              'xos-mobile-link',
              currentPath === item.href && 'is-active',
            ]}
          >
            {item.label}
          </a>
          {item.children && item.children.map((child) => (
            <a
              href={child.href}
              class:list={[
                'xos-mobile-sublink',
                currentPath === child.href && 'is-active',
              ]}
            >
              {child.label}
            </a>
          ))}
        </>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
