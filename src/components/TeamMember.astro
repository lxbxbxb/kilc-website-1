---
interface Props {
  name: string;
  role: string;
  bio: string;
}

const { name, role, bio } = Astro.props;
---

<div class="bg-white rounded-lg p-6 shadow-sm border border-gray-100">
  <!-- Text-only card (no photos on current site) -->
  <div class="w-14 h-14 rounded-full bg-gradient-to-br from-brand-primary to-brand-secondary flex items-center justify-center mb-4">
    <span class="text-white text-xl font-serif font-bold">
      {name.charAt(0)}
    </span>
  </div>
  <h3 class="text-lg font-serif font-semibold text-brand-dark mb-1">{name}</h3>
  <p class="text-brand-primary text-sm font-medium mb-3">{role}</p>
  <p class="text-gray-600 text-sm leading-relaxed">{bio}</p>
</div>
