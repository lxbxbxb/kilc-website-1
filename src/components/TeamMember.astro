---
interface Props {
  name: string;
  role: string;
  bio: string;
}

const { name, role, bio } = Astro.props;
---

<div class="xos-card">
  <!-- Text-only card (no photos on current site) -->
  <div class="w-14 h-14 flex items-center justify-center mb-4 border border-brand-primary/30 bg-brand-primary/5">
    <span class="text-brand-primary text-xl font-serif font-bold">
      {name.charAt(0)}
    </span>
  </div>
  <h3 class="text-lg font-serif font-semibold text-brand-dark dark:text-brand-light mb-1">{name}</h3>
  <p class="text-brand-primary text-xs font-semibold mb-3 uppercase tracking-wider">{role}</p>
  <p class="text-gray-600 dark:text-[#B8C5D6] text-sm leading-relaxed">{bio}</p>
</div>
