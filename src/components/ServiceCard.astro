---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
}

const { title, description, href, icon } = Astro.props;
---

<a href={href} class="group block bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-all duration-200 border border-gray-100 hover:border-brand-primary/20">
  {icon && (
    <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-brand-primary/10 to-brand-secondary/10 flex items-center justify-center mb-4 group-hover:from-brand-primary/20 group-hover:to-brand-secondary/20 transition-colors">
      <span class="text-2xl">{icon}</span>
    </div>
  )}
  <h3 class="text-xl font-serif font-semibold text-brand-dark group-hover:text-brand-primary transition-colors mb-3">
    {title}
  </h3>
  <p class="text-gray-600 text-sm leading-relaxed">
    {description}
  </p>
  <span class="inline-flex items-center gap-1 text-brand-primary text-sm font-medium mt-4 group-hover:gap-2 transition-all">
    Learn more
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </span>
</a>
