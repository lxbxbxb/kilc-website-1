---
import type { Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
  alternatePath: string;
}

const { locale, alternatePath } = Astro.props;
---

<a
  href={alternatePath}
  class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-md text-gray-700 hover:text-brand-primary hover:bg-gray-50 transition-colors"
  aria-label={locale === 'en' ? 'Switch to Chinese' : 'Switch to English'}
>
  {locale === 'en' ? (
    <>
      <img src="/icons/cn.svg" alt="" class="w-4 h-3 rounded-sm" />
      <span>中文</span>
    </>
  ) : (
    <>
      <img src="/icons/gb.svg" alt="" class="w-4 h-3 rounded-sm" />
      <span>EN</span>
    </>
  )}
</a>
