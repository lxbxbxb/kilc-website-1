---
import { t } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const prefix = locale === 'zh' ? '/zh' : '';
---

<div
  id="cookie-banner"
  role="dialog"
  aria-modal="true"
  aria-label={t(locale, 'cookieBanner.title')}
  aria-describedby="cookie-banner-body"
  class="fixed inset-x-0 bottom-0 z-[9999] border-t border-[#C8961E]/30 bg-[#1B2D45] px-4 py-4 sm:px-6 hidden"
>
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex-1">
        <p class="text-sm font-semibold text-[#C8961E]">
          {t(locale, 'cookieBanner.title')}
        </p>
        <p id="cookie-banner-body" class="mt-1 text-xs text-white/70">
          {t(locale, 'cookieBanner.message')}{' '}
          <a href={`${prefix}/cookie-policy`} class="underline transition-colors hover:text-[#C8961E]">
            {t(locale, 'cookieBanner.learnMore')}
          </a>
        </p>
      </div>
      <div class="flex shrink-0 gap-3">
        <button
          id="cookie-decline"
          class="rounded-md border border-[#C8961E]/50 px-4 py-2 text-xs text-[#C8961E]/80 transition-colors hover:border-[#C8961E] hover:text-[#C8961E]"
        >
          {t(locale, 'cookieBanner.decline')}
        </button>
        <button
          id="cookie-accept"
          class="rounded-md bg-[#C8961E] px-4 py-2 text-xs font-medium text-[#1B2D45] transition-opacity hover:opacity-90"
        >
          {t(locale, 'cookieBanner.accept')}
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function () {
  var CONSENT_KEY = 'kilc_cookie_consent_v1';
  var WEBSITE_ID = 'c3272e3b-c8cc-4770-9fa0-55f10d8a162c';
  var ANALYTICS_SRC = 'https://analytics.kilc.co.uk/script.js';

  var banner = document.getElementById('cookie-banner');
  var acceptBtn = document.getElementById('cookie-accept');
  var declineBtn = document.getElementById('cookie-decline');

  function showBanner() {
    if (banner) {
      banner.classList.remove('hidden');
      if (declineBtn) declineBtn.focus();
    }
  }

  function hideBanner() {
    if (banner) banner.classList.add('hidden');
  }

  function loadAnalytics() {
    if (document.querySelector('script[data-website-id="' + WEBSITE_ID + '"]')) return;
    var s = document.createElement('script');
    s.defer = true;
    s.src = ANALYTICS_SRC;
    s.setAttribute('data-website-id', WEBSITE_ID);
    s.setAttribute('data-domains', 'kilc.co.uk');
    document.head.appendChild(s);
  }

  function init() {
    var stored = localStorage.getItem(CONSENT_KEY);
    if (stored === 'accepted') {
      loadAnalytics();
    } else if (stored === null) {
      showBanner();
    }
  }

  if (acceptBtn) {
    acceptBtn.addEventListener('click', function () {
      localStorage.setItem(CONSENT_KEY, 'accepted');
      hideBanner();
      loadAnalytics();
    });
  }

  if (declineBtn) {
    declineBtn.addEventListener('click', function () {
      localStorage.setItem(CONSENT_KEY, 'declined');
      hideBanner();
    });
  }

  window.addEventListener('kilc:reset-consent', function () {
    localStorage.removeItem(CONSENT_KEY);
    showBanner();
  });

  init();
})();
</script>
