---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import { getCollection } from 'astro:content';

const locale = 'zh';

const allCoverage = await getCollection('coverage');
const coverageItems = allCoverage
  .filter(e => e.id.startsWith('zh/'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<PageLayout
  title="Guardian Shield 护航计划 - KILC"
  description="一项专为在英国的海外学生及计划赴英留学的学生量身打造的法律保障服务套餐。"
>
  <Hero
    title="KILC Guardian Shield"
    subtitle="英国国际学生法律保障服务"
    backgroundImage="/images/services/a-group-of-people-sitting-on-top-of-a-lush-green-field.jpg"
    locale={locale}
  />

  <!-- Introduction -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        一项专为在英国的海外学生及计划赴英留学的学生量身打造的法律保障服务套餐。基于 KILC 在国际法与跨境事务方面的专业经验，该套餐全面回应当下中国家长最为关切的问题，包括：英国移民政策变化、针对国际学生的诈骗与欺诈、网络霸凌与线上骚扰，以及从法律角度提供的心理健康支持等。
      </p>
    </div>
  </section>

  <!-- For Parents & Students -->
  <section class="py-16 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="xos-card">
          <h2 class="text-2xl font-serif font-bold text-brand-dark mb-4">致家长</h2>
          <p class="text-gray-600 leading-relaxed">
            在缺乏正确指导的情况下，许多学生在海外遇到法律或安全问题时往往不知所措。Guardian Shield 为您的孩子提供及时可靠的协助——只需一个电话或一条消息，即可获得专业、双语、便捷且负担得起的支持，确保他们在危机中不再孤立无援。我们为在海外求学的学生提供法律保障与日常支持，让您在国内也能真正安心无忧。
          </p>
        </div>
        <div class="xos-card">
          <h2 class="text-2xl font-serif font-bold text-brand-dark mb-4">致学生</h2>
          <p class="text-gray-600 leading-relaxed">
            在英国生活与学习充满机遇与精彩，但你也会面对全新的规则、制度与风险，这些有时会让人感到困惑甚至不公平。许多国际学生因为缺乏可靠的法律协助而被骗、蒙受经济损失，或承受不必要的压力。有了 Guardian Shield，你将始终拥有一支专业团队在你身边，在小问题变成大麻烦之前，为你提供及时指导与支持。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Coverage -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-serif font-bold text-brand-dark mb-12 text-center">服务范围</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {coverageItems.map(item => (
          <div class="xos-card flex items-start gap-4">
            <svg class="w-6 h-6 text-brand-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            <div>
              <h3 class="font-sans font-semibold text-brand-dark mb-1">{item.data.title}</h3>
              <p class="text-gray-600 text-sm">{item.data.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 cta-section">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-serif font-bold mb-6">
        为您的孩子提供全面保障
      </h2>
      <p class="text-lg mb-8 text-white/90">
        联系我们了解 Guardian Shield 详情及定价。
      </p>
      <a
        href="/zh/contact-us"
        class="btn-xos btn-xos-lg"
      >
        联系我们
      </a>
    </div>
  </section>
</PageLayout>
