---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';

const locale = 'zh';

const feeTypes = [
  {
    title: '按小时计费的咨询费率',
    icon: 'M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
    description: '根据专业水平提供具竞争力的小时费率，涵盖初级顾问、咨询顾问及高级专家。',
  },
  {
    title: '固定收费服务',
    icon: 'M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z',
    description: '合同起草、公司设立、合规审查及商标注册等服务均提供透明的固定收费。',
  },
  {
    title: '常年顾问协议',
    icon: 'M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z',
    description: '按月或按年收取常年顾问费，为您的业务需求提供持续且量身定制的专业咨询服务。',
  },
  {
    title: '订阅式收费',
    icon: 'M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99',
    description: '客户可通过支付定期费用，获得特定法律服务或平台的持续使用权。',
  },
];
---

<PageLayout
  title="服务费用 - KILC"
  description="灵活的收费模式，可根据您的需求定制：按小时计费、固定收费、常年顾问费以及订阅式收费等多种选项。"
>
  <Hero
    title="专业咨询服务"
    subtitle="灵活的收费模式，可根据您的需求定制"
    backgroundImage="/images/services/london-bridge.jpg"
    locale={locale}
  />

  <!-- Fee Types -->
  <section class="py-20 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-serif font-bold text-center text-brand-dark mb-4">
        咨询服务费用
      </h2>
      <p class="text-gray-600 text-center max-w-3xl mx-auto mb-12">
        探索我们多样化的咨询服务，为您的业务需求与目标量身定制。
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {feeTypes.map((fee) => (
          <div class="bg-white rounded-lg p-8 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-brand-primary/10 to-brand-secondary/10 flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={fee.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-serif font-bold text-brand-dark mb-4">
              {fee.title}
            </h3>
            <p class="text-gray-600 leading-relaxed">
              {fee.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 cta-section">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-serif font-bold mb-6">
        联系我们了解详情
      </h2>
      <p class="text-lg mb-8 text-white/90">
        欢迎随时咨询我们的服务与收费信息。
      </p>
      <a
        href="/zh/contact-us"
        class="inline-block bg-brand-primary text-brand-dark font-semibold px-8 py-3 rounded-lg hover:bg-brand-accent transition-colors"
      >
        联系我们
      </a>
    </div>
  </section>
</PageLayout>
