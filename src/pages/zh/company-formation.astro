---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import { getCollection } from 'astro:content';

const locale = 'zh';

const allSteps = await getCollection('formationSteps');
const steps = allSteps
  .filter(e => e.id.startsWith('zh/'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<PageLayout
  title="公司注册 - KILC"
  description="KILC 提供企业设立咨询服务，协助客户在英国设立并构建其业务架构。"
>
  <Hero
    title="公司注册"
    subtitle="为您在英国注册公司提供一站式支持。"
    backgroundImage="/images/services/banks.jpg"
    locale={locale}
  />

  <!-- Overview -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-lg text-gray-700 leading-relaxed">
        我们提供企业设立咨询服务，协助客户在英国及其他国家设立并构建其业务架构。我们的顾问团队提供切实可行、以商业需求为导向的专业建议，并可在必要时与受监管的法律或税务专业人士协调合作，提供正式的法律或税务意见。
      </p>
    </div>
  </section>

  <!-- Steps -->
  <section class="py-20 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-serif font-bold text-brand-dark mb-12 text-center">服务内容</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {steps.map((step, index) => (
          <div class="xos-card">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-brand-primary to-brand-secondary flex items-center justify-center text-white font-semibold text-sm mb-4">
              {index + 1}
            </div>
            <h3 class="text-lg font-serif font-bold text-brand-dark mb-3">
              {step.data.title}
            </h3>
            <p class="text-gray-600 leading-relaxed text-sm">
              {step.data.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 cta-section">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-serif font-bold mb-6">
        准备好在英国注册公司了吗？
      </h2>
      <p class="text-lg mb-8 text-white/90">
        联系我们的团队，讨论您的企业设立需求。
      </p>
      <a
        href="/zh/contact-us"
        class="btn-xos btn-xos-lg"
      >
        联系我们
      </a>
    </div>
  </section>
</PageLayout>
