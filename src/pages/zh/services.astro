---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { getCollection } from 'astro:content';

const locale = 'zh';

const allServices = await getCollection('services');
const services = allServices
  .filter(e => e.id.startsWith('zh/'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<PageLayout
  title="我们的服务 - KILC"
  description="KILC 提供全面的法律咨询服务，涵盖移民咨询、刑事辩护、学生支持、房产投资、法律顾问及公司注册等领域。"
>
  <Hero
    title="我们的服务"
    subtitle="KILC 提供战略性咨询与协调服务，涵盖移民、刑事事务、教育、房产投资、法律顾问及公司注册等领域。"
    backgroundImage="/images/hero/bare-trees-in-front-of-white-concrete-building.jpg"
    backgroundPosition="bottom"
    locale={locale}
  />

  <!-- Services Grid -->
  <section class="py-20 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-serif font-bold text-center text-brand-dark mb-4">
        专业领域
      </h2>
      <p class="text-gray-600 text-center max-w-3xl mx-auto mb-12">
        我们在六大核心领域提供专业咨询服务，支持个人和组织应对英国法律与监管环境。
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map(s => (
          <ServiceCard
            title={s.data.title}
            description={s.data.description}
            href={`/zh/${s.id.replace('zh/', '').replace('.md', '')}`}
            icon={s.data.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 cta-section">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-serif font-bold mb-6">
        不确定您需要哪项服务？
      </h2>
      <p class="text-lg mb-8 text-white/90">
        联系我们，我们的团队将帮助您找到适合您情况的支持方案。
      </p>
      <a
        href="/zh/contact-us"
        class="btn-xos btn-xos-lg"
      >
        联系我们
      </a>
    </div>
  </section>
</PageLayout>
