---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import TeamMember from '../../components/TeamMember.astro';
import { getCollection } from 'astro:content';

const locale = 'zh';

const allTeam = await getCollection('team');
const members = allTeam
  .filter(e => e.id.startsWith('zh/') && !e.data.org)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const advisors = allTeam
  .filter(e => e.id.startsWith('zh/') && !!e.data.org)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<PageLayout
  title="团队成员 - KILC"
  description="认识 KILC 团队 — 在国际法律、合规及跨境咨询领域拥有丰富经验的专业人士。"
>
  <Hero
    title="我们的团队"
    subtitle="经验丰富的专业人士，致力于您的成功"
    backgroundImage="/images/services/team.jpg"
    locale={locale}
  />

  <!-- Core Team -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-serif font-bold text-brand-dark mb-12 text-center">高级团队</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {members.map(m => (
          <TeamMember name={m.data.name} role={m.data.role} bio={m.data.bio} />
        ))}
      </div>
    </div>
  </section>

  <!-- Honorary Advisors -->
  <section class="py-16 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-serif font-bold text-brand-dark mb-12 text-center">荣誉顾问</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {advisors.map(a => (
          <div class="xos-card">
            <h3 class="text-lg font-sans font-semibold text-brand-dark">{a.data.name}</h3>
            <p class="text-brand-primary text-sm font-medium mb-2">{a.data.role}</p>
            <p class="text-gray-500 text-sm">{a.data.org}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Join CTA -->
  <section class="py-16 cta-section">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-serif font-bold mb-4">加入我们的团队</h2>
      <p class="text-lg text-white/90 mb-6">
        我们始终欢迎有才华的人士加入我们不断壮大的国际团队。
      </p>
      <a href="/zh/careers" class="btn-xos btn-xos-lg">
        查看职位
      </a>
    </div>
  </section>
</PageLayout>
