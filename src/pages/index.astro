---
import PageLayout from '../layouts/PageLayout.astro';
import { t } from '../i18n/utils';

const locale = 'en';

const serviceCards = [
  {
    title: 'Business Risk & Compliance',
    description: 'Strategic guidance for entering and navigating the UK market with confidence.',
    image: '/images/services/people-having-meeting-on-rectangular-brown-table.jpg',
    imagePosition: 'center 89%',
    href: '/global-market-navigation',
  },
  {
    title: 'Criminal Justice Navigation',
    description: 'Experienced criminal defence representation for individuals and businesses.',
    image: '/images/services/two-hands-are-visible-one-holding-a-pen-and-another-holding-.jpg',
    imagePosition: 'center 64%',
    href: '/criminal',
  },
  {
    title: 'Global Pathway Advisory',
    description: 'Expert visa and immigration advisory tailored to your goals.',
    image: '/images/services/woman-in-suit-shows-document-to-man.jpg',
    imagePosition: 'center 16%',
    href: '/immigration',
  },
  {
    title: 'Real Estate Investment',
    description: 'Protection and advisory for your property investments across the UK.',
    image: '/images/hero/white-concrete-building-near-road-during-daytime.jpg',
    imagePosition: 'center 100%',
    href: '/estate-investment',
  },
];

const galleryImages = [
  { src: '/images/hero/four-men-in-business-attire-are-engaged-in-a-discussion-arou.jpg', position: 'center 70%' },
  { src: '/images/services/a-view-of-a-city-with-tall-buildings.jpg',                    position: 'center 60%' },
  { src: '/images/team/two-men-in-suits-having-coffee-at-a-table.jpg',                   position: 'center 75%' },
  { src: '/images/services/modern-cityscape-with-skyscrapers-and-a-boat-on-water.jpg',   position: 'center 70%' },
  { src: '/images/hero/an-aerial-view-of-a-city-with-tall-buildings.jpg',                position: 'center center' },
  { src: '/images/services/people-having-meeting-on-rectangular-brown-table.jpg',        position: 'center 90%' },
];
---

<PageLayout
  title={t(locale, 'site.title')}
  description={t(locale, 'site.description')}
>
  <!-- XOS Hero -->
  <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <video
        class="absolute inset-0 w-full h-full object-cover"
        autoplay
        muted
        loop
        playsinline
        poster="/images/hero/an-aerial-view-of-a-city-with-tall-buildings.jpg"
      >
        <source src="/video/homepage-hd_1280_720_25fps.mp4" type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-black/55"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 py-24 text-center text-white">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 mb-8">
        <span class="w-2 h-2 rounded-full bg-brand-primary animate-pulse"></span>
        <span class="text-sm font-medium tracking-wide">Now Live · A KILC Product</span>
      </div>

      <h1 class="text-6xl sm:text-7xl lg:text-8xl font-serif font-bold tracking-wider mb-4">
        <span class="bg-gradient-to-r from-brand-primary to-brand-secondary bg-clip-text text-transparent">XOS</span>
      </h1>

      <p class="text-2xl sm:text-3xl lg:text-4xl font-sans font-light italic leading-tight mb-6">
        Cross-Border Compliance, Reimagined.
      </p>

      <p class="text-lg sm:text-xl text-white/85 max-w-2xl mx-auto mb-10">
        The operating system for businesses managing UK and international regulatory obligations — in one secure, intelligent platform.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="https://xos.kilc.co.uk" target="_blank" rel="noopener noreferrer" class="btn-xos btn-xos-lg">
          Open XOS &rarr;
        </a>
        <a href="https://xos.kilc.co.uk#signup" target="_blank" rel="noopener noreferrer" class="btn-xos-outline btn-xos-outline-lg" style="color:#F7F2EA;border-color:rgba(247,242,234,0.4);">
          Sign Up Free
        </a>
        <a href="/contact" class="btn-xos-ghost" style="color:rgba(247,242,234,0.85);">
          Book a Demo &rarr;
        </a>
      </div>

      <p class="text-white/60 text-sm mt-6">
        Free to start · No credit card required
      </p>
    </div>
  </section>

  <!-- Guardian Shield · companion product showcase -->
  <section class="relative py-24 bg-brand-dark text-white reveal overflow-hidden">
    <div class="absolute inset-0 opacity-30 bg-cover bg-center" style="background-image: url('/images/services/a-group-of-people-sitting-on-top-of-a-lush-green-field.jpg');"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-brand-dark/85 via-brand-dark/90 to-brand-dark"></div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 mb-6">
        <span class="w-2 h-2 rounded-full bg-brand-primary animate-pulse"></span>
        <span class="text-xs font-medium tracking-widest uppercase">Also a KILC Product · Now Live</span>
      </div>

      <h2 class="text-5xl sm:text-6xl lg:text-7xl font-serif font-bold tracking-wider mb-3">
        <span class="bg-gradient-to-r from-brand-primary to-brand-goldLight bg-clip-text text-transparent">GUARDIAN SHIELD</span>
      </h2>

      <p class="text-xl sm:text-2xl font-serif italic font-light leading-tight mb-5">
        Legal protection, reimagined for international students.
      </p>

      <p class="text-base sm:text-lg text-white/85 max-w-2xl mx-auto mb-8">
        A bilingual consultancy retainer covering visa, housing, academic compliance, financial safety, and personal welfare — three annual tiers from £1,099.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="https://gs.kilc.co.uk" target="_blank" rel="noopener noreferrer" class="btn-xos btn-xos-lg">
          Open Guardian Shield &rarr;
        </a>
        <a href="https://gs.kilc.co.uk#tiers" target="_blank" rel="noopener noreferrer" class="btn-xos-outline btn-xos-outline-lg" style="color:#F7F2EA;border-color:rgba(247,242,234,0.4);">
          Compare Tiers
        </a>
        <a href="/programme" class="btn-xos-ghost" style="color:rgba(247,242,234,0.85);">
          Learn more &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl mx-auto mt-12 pt-8 border-t border-white/10 text-left">
        <div>
          <p class="text-xs uppercase tracking-widest text-brand-primary font-semibold mb-1">Tier 1 · Essential</p>
          <p class="text-2xl font-serif font-semibold">£1,099<span class="text-sm text-white/60 font-sans font-normal"> /yr</span></p>
          <p class="text-xs text-white/70 mt-1">Knowledge & guidance retainer</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-brand-primary font-semibold mb-1">Tier 2 · Advisory</p>
          <p class="text-2xl font-serif font-semibold">£2,699<span class="text-sm text-white/60 font-sans font-normal"> /yr</span></p>
          <p class="text-xs text-white/70 mt-1">Action plans & escalation pathways</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-brand-primary font-semibold mb-1">Tier 3 · Hands-On</p>
          <p class="text-2xl font-serif font-semibold">£4,999<span class="text-sm text-white/60 font-sans font-normal"> /yr</span></p>
          <p class="text-xs text-white/70 mt-1">Drafting, forms & 24/7 escalation</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-20 bg-brand-light reveal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="section-label">The expertise behind XOS</span>
        <h2 class="text-3xl font-serif font-bold text-brand-dark mb-4 mt-2">
          Built on KILC's legal consultancy
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg">
          XOS is powered by years of frontline legal practice. Beyond the platform, KILC's specialist team supports clients across these areas.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {serviceCards.map((card) => (
          <a href={card.href} class="xos-card group block overflow-hidden p-0">
            <div class="overflow-hidden">
              <img
                src={card.image}
                alt={card.title}
                class="w-full h-52 object-cover group-hover:scale-105 transition-transform duration-300"
                style={`object-position: ${card.imagePosition}`}
                loading="lazy"
              />
            </div>
            <div class="p-7">
              <h3 class="text-xl font-serif font-semibold text-brand-dark group-hover:text-brand-primary transition-colors mb-3">
                {card.title}
              </h3>
              <p class="text-gray-600">
                {card.description}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery: Heading + Mosaic -->
  <section class="py-16 bg-white reveal">
    <div class="max-w-7xl mx-auto px-4 text-center mb-10">
      <h2 class="text-3xl font-serif font-bold text-brand-dark mb-3">Global Legal Expertise</h2>
      <a href="/global-market-navigation" class="text-brand-primary hover:text-brand-accent transition-colors text-sm">
        Empowering enterprises with tailored international legal solutions →
      </a>
    </div>
    <div class="grid grid-cols-3 grid-rows-2">
      {galleryImages.map((img) => (
        <div class="overflow-hidden h-64">
          <img
            src={img.src}
            alt=""
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            style={`object-position: ${img.position}`}
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </section>

  <!-- Contact & Location -->
  <section class="py-20 bg-white reveal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Map -->
        <div class="rounded-lg overflow-hidden shadow-sm border border-gray-200 h-96">
          <iframe
            title="KILC Office Location"
            src="https://www.openstreetmap.org/export/embed.html?bbox=-0.0944%2C51.5246%2C-0.0844%2C51.5286&layer=mapnik&marker=51.5266%2C-0.0894"
            width="100%"
            height="100%"
            style="border:0;"
            loading="lazy"
          ></iframe>
        </div>

        <!-- Address & Hours Panel -->
        <div class="space-y-6">
          <div>
            <h2 class="text-2xl font-serif font-bold text-brand-dark mb-2">Visit Us</h2>
            <p class="text-gray-500 text-sm">We welcome clients by appointment</p>
          </div>

          <div class="flex gap-4">
            <div class="mt-1 text-brand-primary">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-brand-dark text-sm uppercase tracking-wider mb-1">Address</p>
              <p class="text-gray-600">128 City Road<br />London, EC1V 2NX<br />United Kingdom</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="mt-1 text-brand-primary">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-brand-dark text-sm uppercase tracking-wider mb-1">Office Hours</p>
              <p class="text-gray-600">Monday – Friday: 9:00 am – 6:00 pm</p>
              <p class="text-gray-600">Saturday: 10:00 am – 2:00 pm</p>
              <p class="text-gray-500 text-sm mt-1">Closed Sundays & Bank Holidays</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="mt-1 text-brand-primary">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-brand-dark text-sm uppercase tracking-wider mb-1">Email</p>
              <a href="mailto:info@kilc.co.uk" class="text-brand-primary hover:text-brand-accent transition-colors">
                info@kilc.co.uk
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 cta-section reveal">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <span class="section-label">Get started</span>
      <h2 class="text-3xl font-serif font-bold mb-6 mt-2">
        Ready to streamline your cross-border compliance?
      </h2>
      <p class="text-lg mb-8">
        Open XOS today, or book a demo to see how it fits your operations.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="https://xos.kilc.co.uk" target="_blank" rel="noopener noreferrer" class="btn-xos btn-xos-lg">
          Open XOS &rarr;
        </a>
        <a href="/contact" class="btn-xos-outline btn-xos-outline-lg">
          Book a Demo
        </a>
      </div>
    </div>
  </section>
</PageLayout>
