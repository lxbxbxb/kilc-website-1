---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';

const locale = 'en';
---

<PageLayout
  title="Our Services - KILC"
  description="KILC works across international and UK-facing environments — immigration, criminal justice, education, property, legal consultancy, and company formation."
>
  <Hero
    title="Our Services"
    subtitle="KILC works across international and UK-facing environments — providing expert consultancy in immigration, criminal justice, education, property investment, legal advisory, and company formation."
    backgroundImage="/images/hero/bare-trees-in-front-of-white-concrete-building.jpg"
    backgroundPosition="bottom"
    locale={locale}
  />

  <!-- Services Grid -->
  <section class="py-20 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-sans font-bold text-center text-brand-dark mb-4">
        Areas of Expertise
      </h2>
      <p class="text-gray-600 text-center max-w-3xl mx-auto mb-12">
        We provide specialist consultancy across six core practice areas, supporting individuals and organisations navigating the UK legal and regulatory landscape.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <ServiceCard
          title="Global Market Navigation"
          description="Expert advisory and coordinated support to navigate international markets successfully and compliantly. We guide you through risk assessment, regulatory compliance, and business establishment."
          href="/global-market-navigation"
          icon="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418"
        />
        <ServiceCard
          title="Immigration & Mobility"
          description="Comprehensive immigration support for individuals and businesses, including ILR applications, Schengen visas, workforce mobility, and UK relocation planning."
          href="/immigration"
          icon="M6 12 3.269 3.126A59.768 59.768 0 0 1 21.485 12 59.77 59.77 0 0 1 3.27 20.876L5.999 12Zm0 0h7.5"
        />
        <ServiceCard
          title="Criminal Justice Systems"
          description="Specialist guidance through UK criminal justice processes, from understanding procedural pathways to rights frameworks and post-process support."
          href="/criminal"
          icon="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.97Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.97Z"
        />
        <ServiceCard
          title="Student Services"
          description="Dedicated support for international students adjusting to UK life, covering academic challenges, school enforcement matters, and personal difficulties."
          href="/student-services"
          icon="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"
        />
        <ServiceCard
          title="Estate & Investment Protection"
          description="Protecting your UK property investments with guidance on real estate frameworks, acquisition processes, regulatory compliance, and cross-border considerations."
          href="/estate-investment"
          icon="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
        />
        <ServiceCard
          title="Company Formation"
          description="End-to-end support for registering your company in the UK, from entity structuring and Companies House registration to bank account setup."
          href="/company-formation"
          icon="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"
        />
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 cta-section">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-sans font-bold mb-6">
        Not sure which service you need?
      </h2>
      <p class="text-lg mb-8 text-white/90">
        Get in touch and our team will help you identify the right support for your situation.
      </p>
      <a
        href="/contact"
        class="inline-block bg-brand-primary text-brand-dark font-semibold px-8 py-3 rounded-lg hover:bg-brand-accent transition-colors"
      >
        Contact Us
      </a>
    </div>
  </section>
</PageLayout>
