---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import TeamMember from '../components/TeamMember.astro';
import { getCollection } from 'astro:content';

const locale = 'en';

const allTeam = await getCollection('team');
const members = allTeam
  .filter(e => e.id.startsWith('en/') && !e.data.org)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const advisors = allTeam
  .filter(e => e.id.startsWith('en/') && !!e.data.org)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<PageLayout
  title="Our Team - KILC"
  description="Meet the KILC team — experienced professionals in international law, compliance, and cross-border advisory."
>
  <Hero
    title="Our Team"
    subtitle="Experienced professionals dedicated to your success"
    backgroundImage="/images/services/team.jpg"
    locale={locale}
  />

  <!-- Core Team -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-serif font-bold text-brand-dark mb-12 text-center">Leadership Team</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {members.map(m => (
          <TeamMember name={m.data.name} role={m.data.role} bio={m.data.bio} />
        ))}
      </div>
    </div>
  </section>

  <!-- Honorary Advisors -->
  <section class="py-16 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-serif font-bold text-brand-dark mb-12 text-center">Honorary Advisors</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {advisors.map(a => (
          <div class="bg-white rounded-lg p-5 shadow-sm border border-gray-100">
            <h3 class="text-lg font-sans font-semibold text-brand-dark">{a.data.name}</h3>
            <p class="text-brand-primary text-sm font-medium mb-2">{a.data.role}</p>
            <p class="text-gray-500 text-sm">{a.data.org}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Join CTA -->
  <section class="py-16 cta-section">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-serif font-bold mb-4">Join Our Team</h2>
      <p class="text-lg text-white/90 mb-6">
        We're always looking for talented individuals to join our growing international practice.
      </p>
      <a href="/careers" class="inline-block bg-brand-primary text-brand-dark font-semibold px-8 py-3 rounded-lg hover:bg-brand-accent transition-colors">
        View Careers
      </a>
    </div>
  </section>
</PageLayout>
