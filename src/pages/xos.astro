---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';

const locale = 'en';

const features = [
  {
    title: 'Compliance Gap Analysis',
    description: 'Instantly identify where your business stands against UK and international regulatory requirements. Our system maps your current operations against applicable frameworks and highlights areas requiring attention.',
    icon: 'M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z',
  },
  {
    title: 'Document Templates',
    description: 'Access a curated library of legally-informed document templates — from incorporation documents and shareholder agreements to compliance policies and regulatory filings — all tailored for UK cross-border operations.',
    icon: 'M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z',
  },
  {
    title: 'Regulatory Monitor',
    description: 'Stay ahead of legislative and regulatory changes relevant to your sector and jurisdiction. XOS monitors updates across UK, EU, and key international frameworks and alerts you when action is required.',
    icon: 'M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0',
  },
  {
    title: 'Cross-Border Workflows',
    description: 'Manage multi-jurisdictional compliance workflows in one place. XOS coordinates tasks, deadlines, and document submissions across UK, Chinese, and other international regulatory bodies.',
    icon: 'M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418',
  },
  {
    title: 'Reporting & Audit Trail',
    description: 'Generate comprehensive compliance reports for internal governance, board reporting, or regulatory submissions. Every action within XOS is timestamped and logged to provide a clear, defensible audit trail.',
    icon: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z',
  },
  {
    title: 'Secure Client Portal',
    description: 'A dedicated, encrypted workspace for you and your KILC advisors to collaborate securely. Share documents, exchange communications, and track matter progress — all within a single protected environment.',
    icon: 'M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z',
  },
];
---

<PageLayout
  title="XOS — Cross-Border Compliance Operating System | KILC"
  description="XOS is KILC's Cross-Border Compliance Operating System — a secure platform for compliance gap analysis, document templates, regulatory monitoring, and cross-border workflows."
>
  <Hero
    title="XOS"
    subtitle="Cross-Border Compliance Operating System — manage your UK and international regulatory obligations in one secure platform."
    backgroundImage="/images/services/finance.jpg"
    locale={locale}
  />

  <!-- Introduction -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <p class="text-lg text-gray-600 leading-relaxed">
          XOS is KILC's proprietary Cross-Border Compliance Operating System — a secure, intelligent platform designed for businesses operating across international jurisdictions. Whether you are establishing a UK presence, managing ongoing regulatory obligations, or navigating complex multi-jurisdictional requirements, XOS provides the tools and oversight you need in one integrated environment.
        </p>
      </div>

      <!-- Feature Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
        {features.map((feature) => (
          <div class="bg-white rounded-lg p-8 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-brand-primary/10 to-brand-secondary/10 flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-sans font-bold text-brand-dark mb-4">
              {feature.title}
            </h3>
            <p class="text-gray-600 leading-relaxed text-sm">
              {feature.description}
            </p>
          </div>
        ))}
      </div>

      <!-- Access Platform CTA -->
      <div class="max-w-3xl mx-auto bg-brand-light rounded-lg p-10 text-center">
        <h2 class="text-2xl font-sans font-bold text-brand-dark mb-4">
          Access the XOS Client Platform
        </h2>
        <p class="text-gray-600 leading-relaxed mb-8">
          Existing clients can log in to the XOS platform to manage their compliance workflows, access document templates, and collaborate with the KILC team. New clients should contact us to discuss onboarding.
        </p>
        <a
          href="https://platform.kilc.co.uk"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-gradient-to-r from-brand-primary to-brand-secondary text-white font-semibold px-8 py-3 rounded-lg hover:opacity-90 transition-opacity shadow-lg"
        >
          Go to Client Platform &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 cta-section">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-sans font-bold mb-6">
        Ready to streamline your cross-border compliance?
      </h2>
      <p class="text-lg mb-8 text-white/90">
        Contact us to learn more about XOS and how it can support your international operations.
      </p>
      <a
        href="/contact"
        class="inline-block bg-brand-primary text-brand-dark font-semibold px-8 py-3 rounded-lg hover:bg-brand-accent transition-colors"
      >
        Contact Us
      </a>
    </div>
  </section>
</PageLayout>
