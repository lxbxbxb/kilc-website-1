---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
const locale = 'en';

const clusters = [
  {
    id: 'law',
    title: 'Law & Politics',
    icon: 'M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.97Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.97Z',
    description: 'Structured exposure to international legal practice, UK regulatory frameworks, public policy analysis, and cross-border dispute resolution. Ideal for law, politics, and international relations students.',
    tracks: [
      { name: '2-Week Taster', badge: 'Introductory', detail: 'An introduction to international legal practice at KILC. One case study and a final mentor review session.' },
      { name: '4-Week Standard', badge: 'Standard', detail: 'Deeper immersion into immigration law, corporate compliance, and international regulatory work. Two case studies and weekly mentor feedback.' },
      { name: '6-Week Extended', badge: 'Extended', detail: 'A comprehensive placement working alongside KILC legal professionals. Weekly module assessments, a final project, and a completion certificate with professional reference.' },
    ],
  },
  {
    id: 'business',
    title: 'Business, Economics & Finance',
    icon: 'M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z',
    description: 'Practical grounding in UK and international business strategy, financial analysis, market entry, and marketing. Suited to students in business, economics, finance, accounting, and marketing.',
    tracks: [
      { name: '2-Week Taster', badge: 'Introductory', detail: 'An introduction to KILC's business and finance advisory practice. One case study and a final mentor review session.' },
      { name: '4-Week Standard', badge: 'Standard', detail: 'Applied work across market strategy, financial due diligence, and commercial advisory. Two case studies and weekly mentor feedback.' },
      { name: '6-Week Extended', badge: 'Extended', detail: 'A comprehensive placement contributing to live business projects, research, and client-facing work. Weekly module assessments, a final project, and a completion certificate.' },
    ],
  },
];

const eligibility = [
  'University students from any subject area worldwide',
  'A-level students considering a career in law, business, or international affairs',
  'Students seeking UK work experience for visa or career purposes',
  'International students wanting to understand the UK legal and business landscape',
  'Graduates looking to build their professional portfolio',
  'Students from all nationalities and academic backgrounds',
];

const benefits = [
  { title: 'KILC Certificate', desc: 'A certificate of completion issued by KILC upon successful completion of all programme requirements.' },
  { title: 'Professional Reference', desc: 'A written reference from your supervising mentor, available on request after the Extended track.' },
  { title: 'Research & Drafting Skills', desc: 'Hands-on practice in legal and commercial research, case analysis, and professional writing.' },
  { title: 'Cross-Border Knowledge', desc: 'Deep understanding of UK and international law, regulation, and business practice.' },
  { title: 'Weekly Mentor Feedback', desc: 'Structured feedback from KILC professionals on your tasks and progress throughout the programme.' },
  { title: 'Free Placement Matching', desc: 'Complimentary placement matching for Extended-track completers seeking onward host-employer placements. KILC never charges candidates for placement.' },
];
---

<PageLayout
  title="Internship Programme - KILC"
  description="KILC Internship Programme: a fully online, mentor-led internship for university and A-level students worldwide, across Law & Politics and Business, Economics & Finance."
>
  <Hero
    title="Internship Programme"
    subtitle="A fully online, mentor-led internship open to university and A-level students worldwide."
    backgroundImage="/images/services/university.jpg"
    backgroundPosition="center"
    locale={locale}
  />

  <!-- Introduction -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <p class="text-lg text-gray-600 leading-relaxed">
          The KILC Internship Programme combines structured training materials, real-world case studies,
          and direct mentor feedback. Delivered entirely online across two subject clusters and three duration
          tracks — from a 2-week taster to a 6-week extended placement — it gives students worldwide the
          professional skills and UK legal and commercial knowledge needed to stand out.
        </p>
        <p class="text-sm text-gray-400 mt-4 leading-relaxed">
          This programme is currently in its launch phase. Full online registration will open shortly.
          In the meantime, please apply via the contact form or email below.
          Programme details are subject to finalisation pending legal and regulatory review.
        </p>
      </div>

      <!-- Subject Clusters -->
      <div class="space-y-16 mb-20">
        {clusters.map((cluster) => (
          <div>
            <div class="flex items-start gap-4 mb-8">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-brand-primary/10 to-brand-secondary/10 flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-6 h-6 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d={cluster.icon} />
                </svg>
              </div>
              <div>
                <h2 class="text-2xl font-sans font-bold text-brand-dark">{cluster.title}</h2>
                <p class="text-gray-500 text-sm mt-1 leading-relaxed max-w-2xl">{cluster.description}</p>
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pl-0 md:pl-16">
              {cluster.tracks.map((track) => (
                <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                  <div class="flex flex-wrap items-center gap-2 mb-3">
                    <h3 class="text-lg font-sans font-bold text-brand-dark">{track.name}</h3>
                    <span class="inline-block bg-brand-primary/10 text-brand-primary text-xs font-semibold px-2.5 py-0.5 rounded-full">{track.badge}</span>
                  </div>
                  <p class="text-gray-600 text-sm leading-relaxed">{track.detail}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Who Can Apply -->
      <div class="bg-gray-50 rounded-2xl p-10 mb-16">
        <h2 class="text-3xl font-sans font-bold text-brand-dark text-center mb-8">Who Can Apply</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-3xl mx-auto">
          {eligibility.map((item) => (
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <p class="text-gray-600 text-sm">{item}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- What You Will Gain -->
      <div class="max-w-4xl mx-auto mb-16">
        <h2 class="text-3xl font-sans font-bold text-brand-dark text-center mb-10">What You Will Gain</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {benefits.map((item) => (
            <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-100">
              <h4 class="font-semibold text-brand-dark mb-2">{item.title}</h4>
              <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- How to Apply -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-2xl mx-auto text-center px-4">
      <h2 class="text-3xl font-sans font-bold text-brand-dark mb-6">How to Apply</h2>
      <p class="text-gray-600 leading-relaxed mb-8">
        Applications are open year-round. Send your CV and a short cover letter (no more than 300 words)
        stating your preferred subject cluster and track duration to the address below.
        Our team will respond within five working days.
      </p>
      <a
        href="/contact"
        class="inline-block bg-brand-primary text-white font-semibold px-8 py-4 rounded-lg hover:bg-brand-secondary transition-colors"
      >
        Contact Us to Apply
      </a>
      <p class="text-sm text-gray-400 mt-4">
        Or email us directly:
        <a href="mailto:internship@kilc.co.uk" class="underline hover:text-brand-primary">internship@kilc.co.uk</a>
      </p>
    </div>
  </section>
</PageLayout>
