---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';

const locale = 'en';
---

<PageLayout
  title="Company Formation - KILC"
  description="End-to-end support for UK company registration — entity structuring, Companies House filing, bank account setup, and ongoing compliance."
>
  <Hero
    title="Company Formation"
    subtitle="End-to-end support for registering and establishing your company in the UK."
    backgroundImage="/images/services/banks.jpg"
    locale={locale}
  />

  <!-- Introduction -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <p class="text-lg text-gray-600 leading-relaxed">
          Establishing a company in the UK is a critical step for international businesses looking to access the UK market. KILC provides comprehensive support through every stage of the company formation process — from choosing the right entity structure and preparing the required documentation to filing with Companies House and setting up a UK business bank account.
        </p>
      </div>

      <!-- Key Steps -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
        {[
          {
            title: 'Entity Structuring',
            description: 'Advice on choosing the right company structure — limited company, LLP, branch, or subsidiary — based on your business model, tax considerations, and operational requirements.',
            icon: 'M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 0 0 2.25-2.25V6a2.25 2.25 0 0 0-2.25-2.25H6A2.25 2.25 0 0 0 3.75 6v2.25A2.25 2.25 0 0 0 6 10.5Zm0 9.75h2.25A2.25 2.25 0 0 0 10.5 18v-2.25a2.25 2.25 0 0 0-2.25-2.25H6a2.25 2.25 0 0 0-2.25 2.25V18A2.25 2.25 0 0 0 6 20.25Zm9.75-9.75H18a2.25 2.25 0 0 0 2.25-2.25V6A2.25 2.25 0 0 0 18 3.75h-2.25A2.25 2.25 0 0 0 13.5 6v2.25a2.25 2.25 0 0 0 2.25 2.25Z',
          },
          {
            title: 'Companies House Registration',
            description: 'Full support with preparing and filing your incorporation documents, including Memorandum and Articles of Association, appointment of directors, and registered office setup.',
            icon: 'M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z',
          },
          {
            title: 'Bank Account Setup',
            description: 'Assistance with opening a UK business bank account — navigating the due diligence requirements that can be particularly challenging for international directors and shareholders.',
            icon: 'M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z',
          },
          {
            title: 'HMRC Registration',
            description: 'Registration for Corporation Tax, VAT (where applicable), and PAYE — ensuring your company meets its tax obligations from day one.',
            icon: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z',
          },
          {
            title: 'Compliance Framework',
            description: 'Setting up the compliance foundations your company needs — including data protection registration, AML policies, and sector-specific regulatory requirements.',
            icon: 'M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z',
          },
          {
            title: 'Ongoing Support',
            description: 'Continuing advisory support after formation — including annual filings, confirmation statements, changes to company details, and ongoing corporate governance.',
            icon: 'M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99',
          },
        ].map((step) => (
          <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-brand-primary/10 to-brand-secondary/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={step.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-sans font-bold text-brand-dark mb-3">
              {step.title}
            </h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              {step.description}
            </p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 cta-section">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-sans font-bold mb-6">
        Ready to form your UK company?
      </h2>
      <p class="text-lg mb-8 text-white/90">
        Contact us to discuss your company formation requirements and get started.
      </p>
      <a
        href="/contact"
        class="inline-block bg-brand-primary text-brand-dark font-semibold px-8 py-3 rounded-lg hover:bg-brand-accent transition-colors"
      >
        Contact Us
      </a>
    </div>
  </section>
</PageLayout>
