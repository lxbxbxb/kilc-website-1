---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import { getCollection } from 'astro:content';

const locale = 'en';

const allCoverage = await getCollection('coverage');
const coverageItems = allCoverage
  .filter(e => e.id.startsWith('en/'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<PageLayout
  title="KILC Guardian Shield - Legal Protection for International Students"
  description="Comprehensive legal protection package for international students in the UK — covering visa, fraud protection, cyber safety, mental health, housing, and more."
>
  <Hero
    title="KILC Guardian Shield"
    subtitle="Comprehensive legal protection designed for international students and their families."
    backgroundImage="/images/services/a-group-of-people-sitting-on-top-of-a-lush-green-field.jpg"
    locale={locale}
  />

  <!-- Introduction -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <p class="text-lg text-gray-600 leading-relaxed">
          The KILC Guardian Shield is a comprehensive legal protection package designed specifically for international students studying in the UK. It provides ongoing access to expert guidance and support across the full range of challenges that students may encounter — giving both students and their families peace of mind throughout their time in the UK.
        </p>
      </div>

      <!-- For Parents / For Students -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-20">
        <div class="xos-card">
          <div class="w-14 h-14 rounded-full bg-gradient-to-br from-brand-primary/10 to-brand-secondary/10 flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
            </svg>
          </div>
          <h2 class="text-2xl font-serif font-bold text-brand-dark mb-4">
            For Parents
          </h2>
          <p class="text-gray-600 leading-relaxed">
            Sending your child to study abroad is a significant decision. The Guardian Shield gives you confidence that your child has access to expert legal support whenever they need it. You receive regular updates and can rest assured that a dedicated team is available to help navigate any difficulties that arise — from everyday challenges to urgent situations.
          </p>
        </div>
        <div class="xos-card">
          <div class="w-14 h-14 rounded-full bg-gradient-to-br from-brand-primary/10 to-brand-secondary/10 flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
            </svg>
          </div>
          <h2 class="text-2xl font-serif font-bold text-brand-dark mb-4">
            For Students
          </h2>
          <p class="text-gray-600 leading-relaxed">
            Studying in a new country brings exciting opportunities and real challenges. The Guardian Shield ensures you always have somewhere to turn when things get difficult. Whether it is a visa question, a housing dispute, an academic issue, or a personal safety concern — our team is here to provide clear guidance and practical support so you can focus on your studies.
          </p>
        </div>
      </div>

      <!-- Service Coverage -->
      <h2 class="text-3xl font-serif font-bold text-center text-brand-dark mb-12">
        Service Coverage
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        {coverageItems.map((item, index) => (
          <div class="xos-card flex gap-4">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-brand-primary to-brand-secondary flex items-center justify-center text-white text-sm font-semibold">
                {index + 1}
              </div>
            </div>
            <div>
              <h3 class="font-serif font-bold text-brand-dark mb-1">
                {item.data.title}
              </h3>
              <p class="text-gray-600 text-sm leading-relaxed">
                {item.data.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 cta-section">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-serif font-bold mb-6">
        Protect your child's journey in the UK
      </h2>
      <p class="text-lg mb-8 text-white/90">
        Contact us to learn more about the Guardian Shield programme and how it can provide peace of mind for your family.
      </p>
      <a
        href="/contact"
        class="btn-xos btn-xos-lg"
      >
        Enquire Now
      </a>
    </div>
  </section>
</PageLayout>
