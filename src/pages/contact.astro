---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';

const locale = 'en';
---

<PageLayout
  title="Contact Us - KILC"
  description="Get in touch with Keane International Legal Consultancy. 128 City Road, London EC1V 2NX. info@kilc.co.uk. WeChat: KILCL-UK."
>
  <Hero
    title="Contact Us"
    subtitle="We would love to hear from you. Get in touch to discuss how we can help."
    backgroundImage="/images/hero/a-red-double-decker-bus-driving-down-a-city-street.jpg"
    locale={locale}
  />

  <!-- Contact Section -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-sans font-bold text-brand-dark mb-6">
            Send Us a Message
          </h2>
          <p class="text-gray-600 mb-8">
            Fill in the form below and a member of our team will get back to you as soon as possible.
          </p>
          <ContactForm locale={locale} />
        </div>

        <!-- Contact Details -->
        <div>
          <h2 class="text-2xl font-sans font-bold text-brand-dark mb-6">
            Contact Details
          </h2>

          <div class="space-y-8">
            <!-- Address -->
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-brand-primary/10 to-brand-secondary/10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="font-semibold text-brand-dark mb-1">Office Address</h3>
                <p class="text-gray-600">
                  128 City Road<br />
                  London EC1V 2NX<br />
                  United Kingdom
                </p>
              </div>
            </div>

            <!-- Business Hours -->
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-brand-primary/10 to-brand-secondary/10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="font-semibold text-brand-dark mb-1">Business Hours</h3>
                <p class="text-gray-600">
                  Monday — Friday<br />
                  9:00 AM — 5:00 PM (GMT)
                </p>
              </div>
            </div>

            <!-- Email -->
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-brand-primary/10 to-brand-secondary/10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="font-semibold text-brand-dark mb-1">Email</h3>
                <a href="mailto:info@kilc.co.uk" class="text-brand-primary hover:text-brand-secondary transition-colors">
                  info@kilc.co.uk
                </a>
              </div>
            </div>

            <!-- WeChat -->
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-brand-primary/10 to-brand-secondary/10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="font-semibold text-brand-dark mb-1">WeChat</h3>
                <p class="text-gray-600">KILCL-UK</p>
              </div>
            </div>
          </div>

          <!-- Map placeholder -->
          <div class="mt-10 bg-brand-light rounded-lg p-6 border border-gray-200">
            <p class="text-sm text-gray-500 text-center">
              128 City Road, London EC1V 2NX — near Old Street station (Northern line)
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
